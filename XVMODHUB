local running = false

button.MouseButton1Click:Connect(function()
    running = not running
    button.Text = running and "INF LEVEL: ON" or "INF LEVEL"

    while running do
        local player = game.Players.LocalPlayer
        if player then

            
            if player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild("Level") then
                local level = player.leaderstats.Level
                level.Value += 8

                
                if player.leaderstats:FindFirstChild("Damage") then
                    player.leaderstats.Damage.Value = level.Value * 2 + 1
                end
            end

            if player:FindFirstChild("Exp") then
                local exp = player.Exp

             
                exp.Value = exp.Value + 40000000000

               
                if exp.Value >= 20000000000000000000 then
                    exp.Value = 0
                end
            end
        end

        task.wait(0.2)
    end
end)
